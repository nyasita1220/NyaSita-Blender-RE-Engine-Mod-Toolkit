# --------------------------------------------------------------------------- #
#   Paths
# --------------------------------------------------------------------------- #
ADDON_DIR = os.path.dirname(__file__)
PRESETS_DIR = os.path.join(ADDON_DIR, "presets")


def _ensure_presets_dir():
    os.makedirs(PRESETS_DIR, exist_ok=True)


